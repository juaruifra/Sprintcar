# Puerto y modo del servidor
WEB_SERVER_PORT=tu puerto aqui
NODE_ENV=development | production
PMA_SECRET=tu contraseña para phpmyadmin aqui (BLOWFISH_SECRET)

# BBDD
DB_HOST=database # nombre del contendor de la base de datos
DB_PORT=3306
DB_DATABASE=tu base de datos aqui
DB_USER=tu usuario aqui
DB_PASSWORD=tu contraseña aqui
DB_ROOT_PASSWORD=tu contraseña root aqui

# JWT Auth
JWT_SECRET=tu secret JWT aqui
JWT_EXPIRES_IN=tiempo de expiración del token (ejemplo: 1d, 12h, 30m)

# Datos iniciales
# Los usuarios y futuros datos de seed se definen en src/db/seeding/data/*.json
# y se cargan con un único comando: npm run seed

# Supabase Storage (solo para avatar, gestionado por backend)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
SUPABASE_AVATARS_BUCKET=avatars